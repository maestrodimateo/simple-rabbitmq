{
    "name": "maestrodimateo/simple-rabbitmq",
    "description": "A simple, dev-friendly Laravel wrapper for RabbitMQ",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3 || ^8.4",
        "php-amqplib/php-amqplib": "^3.7",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Maestrodimateo\\SimpleRabbitMQ\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Maestrodimateo\\SimpleRabbitMQ\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maestrodimateo\\SimpleRabbitMQ\\SimpleRabbitMQServiceProvider"
            ],
            "aliases": {
                "RabbitMQ": "Maestrodimateo\\SimpleRabbitMQ\\Facades\\RabbitMQ"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
